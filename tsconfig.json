{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "legion": ["./packages/legion/src/index.ts"],
      "legion-kimi-code": ["./packages/legion-kimi-code/src/index.ts"],
      "legion-discord": ["./packages/legion-discord/src/index.ts"]
    }
  },
  "references": [
    { "path": "./packages/legion" },
    { "path": "./packages/legion-kimi-code" },
    { "path": "./packages/legion-discord" }
  ],
  "files": []
}
